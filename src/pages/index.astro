---
// Runs at build time. Read the finished dataset so the headline numbers
// on the page always match what's actually on the map.
import { readFileSync } from "node:fs";

const geojson = JSON.parse(readFileSync("public/sites.geojson", "utf8"));
const siteCount = geojson.features.length;
const councils = [...new Set(geojson.features.map((f) => f.properties.council))];
const councilCount = councils.length;

// stats.json (written by the pipeline) holds counts the geojson can't, like the
// number of sites we couldn't place on the map.
const stats = JSON.parse(readFileSync("public/stats.json", "utf8"));
const reviewCount = stats.review;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Derelict Ireland</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <script src="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.js"></script>
  <link href="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.css" rel="stylesheet" />
  <style>
    :root {
      --ink: #1a1a1a;
      --muted: #666;
      --accent: #c0392b;
      --line: #e5e5e5;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
      color: var(--ink);
      line-height: 1.5;
    }
    header {
      max-width: 820px;
      margin: 0 auto;
      padding: 3rem 1.25rem 1.5rem;
    }
    h1 {
      margin: 0 0 .5rem;
      font-size: 2.25rem;
      letter-spacing: -0.02em;
    }
    .lede {
      margin: 0 0 1.5rem;
      font-size: 1.1rem;
      color: var(--muted);
      max-width: 60ch;
    }
    .stats {
      display: flex;
      gap: 2.5rem;
      flex-wrap: wrap;
    }
    .stat .num {
      font-size: 1.9rem;
      font-weight: 700;
      color: var(--accent);
    }
    .stat .label {
      font-size: .85rem;
      text-transform: uppercase;
      letter-spacing: .05em;
      color: var(--muted);
    }
    .map-box {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 1.25rem;
    }
    #map {
      height: 60vh;
      min-height: 420px;
      border: 1px solid var(--line);
      border-radius: 10px;
      overflow: hidden;
      box-shadow: 0 1px 3px rgba(0, 0, 0, .06);
    }
    footer {
      max-width: 820px;
      margin: 0 auto;
      padding: 1.5rem 1.25rem 3rem;
      font-size: .9rem;
      color: var(--muted);
    }
    footer a { color: var(--accent); }
  </style>
</head>
<body>
  <header>
    <h1>Derelict Ireland</h1>
    <p class="lede">
      A map of derelict sites across Ireland, built from the registers councils
      are legally required to keep. Click any pin to see the address and
      register reference.
    </p>
    <div class="stats">
      <div class="stat">
        <div class="num">{siteCount}</div>
        <div class="label">Sites mapped</div>
      </div>
      <div class="stat">
        <div class="num">{councilCount}</div>
        <div class="label">Councils</div>
      </div>
      <div class="stat">
        <div class="num">{reviewCount}</div>
        <div class="label">Not yet mapped</div>
      </div>
    </div>
  </header>

  <div class="map-box">
    <div id="map"></div>
  </div>

  <footer>
    Work in progress. Currently covering {councils.join(", ")}. Data comes from
    each council's public derelict sites register. Not an official source.
    <br />
    <a href="https://github.com/ACoci86/derelict-ireland">View the code on GitHub</a>
  </footer>

  <script>
    const map = new maplibregl.Map({
      container: "map",
      style: "https://basemaps.cartocdn.com/gl/positron-gl-style/style.json",  // clean light basemap (CARTO Positron, no API key)
      center: [-6.26, 53.35],                              // Dublin city, lon/lat
      zoom: 11,
    });

    map.on("load", async () => {
      // public/sites.geojson is served at the site root, so fetch "/sites.geojson".
      const geojson = await (await fetch("/sites.geojson")).json();

      map.addSource("sites", { type: "geojson", data: geojson });
      map.addLayer({
        id: "site",
        type: "circle",
        source: "sites",
        paint: {
          "circle-color": "#c0392b",
          "circle-radius": 7,
          "circle-stroke-width": 1.5,
          "circle-stroke-color": "#fff",
        },
      });

      map.on("click", "site", (e) => {
        const p = e.features[0].properties;
        new maplibregl.Popup()
          .setLngLat(e.features[0].geometry.coordinates)
          .setHTML(`<strong>${p.address}</strong><br>${p.council}<br>ref: ${p.register_ref}`)
          .addTo(map);
      });
      map.on("mouseenter", "site", () => (map.getCanvas().style.cursor = "pointer"));
      map.on("mouseleave", "site", () => (map.getCanvas().style.cursor = ""));
    });
  </script>
</body>
</html>
