---
// Runs at build time. Read the finished dataset so the headline numbers
// on the page always match what's actually on the map.
import { readFileSync } from "node:fs";

const geojson = JSON.parse(readFileSync("public/sites.geojson", "utf8"));
const siteCount = geojson.features.length;
const councils = [...new Set(geojson.features.map((f) => f.properties.council))];
const councilCount = councils.length;

// stats.json (written by the pipeline) holds counts the geojson can't, like the
// number of sites we couldn't place on the map.
const stats = JSON.parse(readFileSync("public/stats.json", "utf8"));
const reviewCount = stats.review;
const councilStats: { council: string; mapped: number; review: number }[] = stats.councils ?? [];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Derelict Ireland</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <script src="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.js"></script>
  <link href="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.css" rel="stylesheet" />
  <style>
    :root {
      --ink: #1a1a1a;
      --muted: #666;
      --accent: #c0392b;
      --line: #e5e5e5;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
      color: var(--ink);
      line-height: 1.5;
    }
    header {
      max-width: 820px;
      margin: 0 auto;
      padding: 3rem 1.25rem 1.5rem;
      text-align: center;
    }
    h1 {
      margin: 0 0 .5rem;
      font-size: 2.25rem;
      letter-spacing: -0.02em;
    }
    .lede {
      margin: 0 auto 1.5rem;
      font-size: 1.1rem;
      color: var(--muted);
      max-width: 60ch;
    }
    .stats {
      display: flex;
      gap: 2.5rem;
      flex-wrap: wrap;
      justify-content: center;
    }
    .stat .num {
      font-size: 1.9rem;
      font-weight: 700;
      color: var(--accent);
    }
    .stat .label {
      font-size: .85rem;
      text-transform: uppercase;
      letter-spacing: .05em;
      color: var(--muted);
    }
    .map-box {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 1.25rem;
    }
    #map {
      height: 60vh;
      min-height: 420px;
      border: 1px solid var(--line);
      border-radius: 10px;
      overflow: hidden;
      box-shadow: 0 1px 3px rgba(0, 0, 0, .06);
    }
    .coverage {
      max-width: 820px;
      margin: 2.5rem auto 0;
      padding: 0 1.25rem;
    }
    .coverage h2 {
      font-size: 1.3rem;
      letter-spacing: -0.01em;
      margin: 0 0 1rem;
      text-align: center;
    }
    .table-card {
      border: 1px solid var(--line);
      border-radius: 10px;
      overflow: hidden;
      box-shadow: 0 1px 3px rgba(0, 0, 0, .06);
      background: #fff;
    }
    .table-scroll { overflow-x: auto; }
    table {
      width: 100%;
      border-collapse: collapse;
      font-size: .95rem;
    }
    thead th {
      text-align: left;
      font-size: .72rem;
      text-transform: uppercase;
      letter-spacing: .06em;
      color: var(--muted);
      font-weight: 600;
      padding: .85rem .9rem;
      background: #fafafa;
      border-bottom: 1px solid var(--line);
      white-space: nowrap;
    }
    th.n, td.n { text-align: center; font-variant-numeric: tabular-nums; }
    tbody td {
      padding: .6rem .9rem;
      border-bottom: 1px solid var(--line);
    }
    tbody tr:hover td { background: #faf6f5; }
    td.council { font-weight: 500; white-space: nowrap; }
    td.mapped { color: var(--accent); font-weight: 600; }
    td.dim { color: var(--muted); }
    .cov { display: flex; align-items: center; gap: .6rem; min-width: 130px; }
    .cov-track {
      flex: 1;
      height: 7px;
      border-radius: 4px;
      background: var(--line);
      overflow: hidden;
    }
    .cov-fill { height: 100%; background: var(--accent); border-radius: 4px; }
    .cov-pct {
      font-size: .8rem;
      color: var(--muted);
      font-variant-numeric: tabular-nums;
      width: 2.6em;
      text-align: right;
    }
    tfoot td {
      padding: .75rem .9rem;
      border-top: 2px solid var(--line);
      font-weight: 700;
      background: #fafafa;
    }
    tfoot td.n { font-variant-numeric: tabular-nums; }
    footer {
      max-width: 820px;
      margin: 0 auto;
      padding: 1.5rem 1.25rem 3rem;
      font-size: .9rem;
      color: var(--muted);
      text-align: center;
    }
    footer a { color: var(--accent); }
  </style>
</head>
<body>
  <header>
    <h1>Derelict Ireland</h1>
    <p class="lede">
      A map of derelict sites across Ireland, built from the registers councils
      are legally required to keep. Click any pin to see the address and
      register reference.
    </p>
    <div class="stats">
      <div class="stat">
        <div class="num">{siteCount}</div>
        <div class="label">Sites mapped</div>
      </div>
      <div class="stat">
        <div class="num">{councilCount}</div>
        <div class="label">Councils</div>
      </div>
      <div class="stat">
        <div class="num">{reviewCount}</div>
        <div class="label">Not yet mapped</div>
      </div>
    </div>
  </header>

  <div class="map-box">
    <div id="map"></div>
  </div>

  <section class="coverage">
    <h2>Coverage by council</h2>
    <div class="table-card">
      <div class="table-scroll">
        <table>
          <thead>
            <tr>
              <th>Council</th>
              <th class="n">Mapped</th>
              <th class="n">Not yet mapped</th>
              <th class="n">Total</th>
              <th>Coverage</th>
            </tr>
          </thead>
          <tbody>
            {councilStats.map((c) => {
              const total = c.mapped + c.review;
              const pct = total ? Math.round((c.mapped / total) * 100) : 0;
              return (
                <tr>
                  <td class="council">{c.council}</td>
                  <td class="n mapped">{c.mapped}</td>
                  <td class="n dim">{c.review || "0"}</td>
                  <td class="n">{total}</td>
                  <td>
                    <div class="cov">
                      <div class="cov-track"><div class="cov-fill" style={`width:${pct}%`}></div></div>
                      <span class="cov-pct">{pct}%</span>
                    </div>
                  </td>
                </tr>
              );
            })}
          </tbody>
          <tfoot>
            <tr>
              <td>All councils</td>
              <td class="n">{siteCount}</td>
              <td class="n">{reviewCount}</td>
              <td class="n">{siteCount + reviewCount}</td>
              <td>
                <div class="cov">
                  <div class="cov-track"><div class="cov-fill" style={`width:${Math.round((siteCount / (siteCount + reviewCount)) * 100)}%`}></div></div>
                  <span class="cov-pct">{Math.round((siteCount / (siteCount + reviewCount)) * 100)}%</span>
                </div>
              </td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>
  </section>

  <footer>
    Work in progress. Currently covering {councils.join(", ")}. Data comes from
    each council's public derelict sites register. Not an official source.
    <br />
    <a href="https://github.com/ACoci86/derelict-ireland">View the code on GitHub</a>
  </footer>

  <script>
    const map = new maplibregl.Map({
      container: "map",
      style: "https://basemaps.cartocdn.com/gl/positron-gl-style/style.json",  // clean light basemap (CARTO Positron, no API key)
      center: [-8.0, 53.4],                                // middle of Ireland, lon/lat
      zoom: 6,
    });

    map.on("load", async () => {
      // public/sites.geojson is served at the site root, so fetch "/sites.geojson".
      const geojson = await (await fetch("/sites.geojson")).json();

      map.addSource("sites", { type: "geojson", data: geojson });

      // Frame the whole dataset (i.e. the island) rather than a fixed city.
      const lons = geojson.features.map((f: any) => f.geometry.coordinates[0]);
      const lats = geojson.features.map((f: any) => f.geometry.coordinates[1]);
      if (lons.length) {
        map.fitBounds(
          [[Math.min(...lons), Math.min(...lats)], [Math.max(...lons), Math.max(...lats)]],
          { padding: 40, duration: 0 }
        );
        map.setZoom(map.getZoom() - 1);       // pull back one scroll step
      }

      map.addLayer({
        id: "site",
        type: "circle",
        source: "sites",
        paint: {
          "circle-color": "#c0392b",
          "circle-radius": 7,
          "circle-stroke-width": 1.5,
          "circle-stroke-color": "#fff",
        },
      });

      map.on("click", "site", (e) => {
        const p = e.features[0].properties;
        new maplibregl.Popup()
          .setLngLat(e.features[0].geometry.coordinates)
          .setHTML(`<strong>${p.address}</strong><br>${p.council}<br>ref: ${p.register_ref}`)
          .addTo(map);
      });
      map.on("mouseenter", "site", () => (map.getCanvas().style.cursor = "pointer"));
      map.on("mouseleave", "site", () => (map.getCanvas().style.cursor = ""));
    });
  </script>
</body>
</html>
