---
// This top section runs at build time. We don't need it yet, so it's empty.
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Derelict Ireland</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <script src="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.js"></script>
  <link href="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.css" rel="stylesheet" />
  <style>
    body { margin: 0; }
    #map { height: 100vh; }
  </style>
</head>
<body>
  <div id="map"></div>
  <script>
    const map = new maplibregl.Map({
      container: "map",
      style: "https://demotiles.maplibre.org/style.json",  // free demo basemap
      center: [-6.15, 53.28],                              // Dún Laoghaire, lon/lat
      zoom: 11,
    });

    map.on("load", async () => {
      // public/sites.geojson is served at the site root, so fetch "/sites.geojson".
      const geojson = await (await fetch("/sites.geojson")).json();

      map.addSource("sites", { type: "geojson", data: geojson });
      map.addLayer({
        id: "site",
        type: "circle",
        source: "sites",
        paint: {
          "circle-color": "#c0392b",
          "circle-radius": 7,
          "circle-stroke-width": 1.5,
          "circle-stroke-color": "#fff",
        },
      });

      map.on("click", "site", (e) => {
        const p = e.features[0].properties;
        new maplibregl.Popup()
          .setLngLat(e.features[0].geometry.coordinates)
          .setHTML(`<strong>${p.address}</strong><br>${p.council}<br>ref: ${p.register_ref}`)
          .addTo(map);
      });
      map.on("mouseenter", "site", () => (map.getCanvas().style.cursor = "pointer"));
      map.on("mouseleave", "site", () => (map.getCanvas().style.cursor = ""));
    });
  </script>
</body>
</html>